<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>

    const gennemsnitCanvas = document.getElementById('gennemsnitChart');
    const categoryGennemsnitData = <%- JSON.stringify(categoryGennemsnit)%>;

    const labels = Object.keys(categoryGennemsnitData); //Dette trækker alle nøglerne (dvs. "Mejeri", "Kød", "Brød", "Grønt") ud i et array:
    const dataValues = Object.values(categoryGennemsnitData); // Dette trækker alle værdierne (dvs. tallene: 12.3, 9.1, 7.8, 5.4) ud i et array:

    new Chart(gennemsnitCanvas,{
        type: 'bar',
        data:{
            labels: labels,
            datasets: [
                {
                    label: 'Gennemsnitlig rabat (%)',
                    data: dataValues,
                    backgroundColor: [
                        'rgba(255, 99, 132, 0.2)',
                        'rgba(54, 162, 235, 0.2)',
                        'rgba(255, 206, 86, 0.2)',
                        'rgba(75, 192, 192, 0.2)'
                    ],
                    borderColor: [
                        'rgb(255, 99, 132)',
                        'rgb(54, 162, 235)',
                        'rgb(255, 206, 86)',
                        'rgb(75, 192, 192)'
                    ],
                    borderWidth: 1
                }
            ]
        },
        options: {
            plugins: {
                legend: {
                    onclick: null
                }
            },

            scales: {
                y:{
                    title: {
                        display: true,
                        text: 'Rabat i procent'
                    }
                },
                x: {
                    title: {
                        display : true,
                        text: 'Produktkategori'
                    }
                }
            }
        }
    });




    const underkategoriCanvas = document.getElementById('underkategoriChart');
   let underkategoriChart = '';

   async function hentOgVisData(datasetNavn){ // Sender en POST-anmodning til '/' (dvs. forsiden af din Express-server).
       const response = await fetch('/', { // Headeren: Fortæller at det er JSON-data.
           method: 'POST',
           headers:{
               'Content-Type': 'application/json'
           },
           body: JSON.stringify({dataset: datasetNavn}) // Body: Sender { dataset: datasetNavn } som JSON.
       });
       // Dette kalder typisk en app.post('/', ...)-rute i din backend, som returnerer data til grafen.

       let data = await response.json(); // Afventer svaret fra serveren og konverterer det fra JSON til JavaScript-objekt.

       const labels = Object.keys(data);
       const values = Object.values(data);

       if (underkategoriChart){ //Når man bruger fx Chart.js og skifter data (som i din hentOgVisData()-funktion), er det god praksis at slette den gamle graf først, inden man tegner en ny.Ellers risikerer man at få flere grafer oven i hinanden, hvilket kan forvrænge udseendet eller give fejl.
           underkategoriChart.destroy();
       }

       underkategoriChart = new Chart(underkategoriCanvas,{
        type: 'bar',
        data:{
            labels: labels,
            datasets: [
                {
                    label: `Antal produkter prisnedsat i ${datasetNavn}`,
                    data: values,
                    backgroundColor: [
                        'rgba(255, 99, 132, 0.2)',
                        'rgba(54, 162, 235, 0.2)',
                        'rgba(255, 206, 86, 0.2)',
                        'rgba(75, 192, 192, 0.2)',
                        'rgba(153, 102, 255, 0.2)',
                        'rgba(255, 159, 64, 0.2)',
                        'rgba(199, 199, 199, 0.2)',
                        'rgba(83, 102, 255, 0.2)',
                        'rgba(255, 102, 255, 0.2)',
                        'rgba(102, 255, 204, 0.2)',
                        'rgba(255, 204, 102, 0.2)',
                        'rgba(102, 153, 255, 0.2)',
                        'rgba(255, 153, 204, 0.2)',
                        'rgba(204, 255, 153, 0.2)',
                        'rgba(153, 204, 255, 0.2)',
                        'rgba(255, 153, 102, 0.2)'
                    ],
                    borderColor: [
                        'rgb(255, 99, 132)',
                        'rgb(54, 162, 235)',
                        'rgb(255, 206, 86)',
                        'rgb(75, 192, 192)',
                        'rgb(153, 102, 255)',
                        'rgb(255, 159, 64)',
                        'rgb(199, 199, 199)',
                        'rgb(83, 102, 255)',
                        'rgb(255, 102, 255)',
                        'rgb(102, 255, 204)',
                        'rgb(255, 204, 102)',
                        'rgb(102, 153, 255)',
                        'rgb(255, 153, 204)',
                        'rgb(204, 255, 153)',
                        'rgb(153, 204, 255)',
                        'rgb(255, 153, 102)'
                    ],
                    borderWidth: 1
                }
            ]
        },
        options: {
            plugins: {
                legend: {
                    onclick: null
                }
            },

            scales: {
                y:{
                    title: {
                        display: true,
                        text: 'Antal varer'
                    }
                },
                x: {
                    title: {
                        display : true,
                        text: 'UnderKategori'
                    }
                }
            }
        }
    });
   }

   const mejeriKnap = document.getElementById('knapmejeri');
   const kodKnap = document.getElementById('knapkød');

   mejeriKnap.addEventListener('click', function (){
       hentOgVisData('Mejeri og køl')
   });

   kodKnap.addEventListener('click', function (){
       hentOgVisData('Kød og fisk')
   });
    hentOgVisData('Mejeri og køl');


    const faerdigretCanvas = document.getElementById('faerdigretChart');
   const faerdigretVariantData = <%- JSON.stringify(faerdigretVariant)%>

    const variant = Object.keys(faerdigretVariantData);
    const variantDataValues = Object.values(faerdigretVariantData);

    new Chart(faerdigretCanvas, {
        type: 'doughnut',
        data: {
            labels: variant,
            datasets: [
                {
                    label: 'Produktvarianter prisnedsat i underkategorien Færdigretter',
                    data: variantDataValues,
                    backgroundColor: [
                        'rgba(255, 99, 132, 0.2)',
                        'rgba(54, 162, 235, 0.2)',
                        'rgba(255, 159, 64, 0.2)',
                        'rgba(75, 192, 192, 0.2)',
                        'rgba(255, 223, 186, 0.2)'
                    ],
                    hoverOffset: 4
                }]
        },
    });



</script>
</body>
